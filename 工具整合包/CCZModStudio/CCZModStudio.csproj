    </Content>
    <Content Include="Assets\CmfManualSeeds\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>Assets\CmfManualSeeds\%(RecursiveDir)%(Filename)%(Extension)</TargetPath>
