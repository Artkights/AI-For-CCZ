      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>Package\self-check.json</TargetPath>
    </Content>
  </ItemGroup>

  <!-- Referencing projects must consume TargetPath before the standalone build layout moves it under net. -->
  <Target Name="ArrangeSelfContainedBuildLayout"
          AfterTargets="Build"
          Condition="'$(BuildingSolutionFile)' != 'true' and '$(CczSkipStandaloneBuildLayout)' != 'true' and '$(Configuration)' == 'Release' and '$(_IsPublishing)' != 'true' and '$(SelfContained)' == 'true' and '$(RuntimeIdentifier)' != '' and '$(PublishSingleFile)' != 'true'">
    <PropertyGroup>
      <_CczBuildLayoutRoot>$([System.IO.Path]::GetFullPath('$(TargetDir)'))</_CczBuildLayoutRoot>
      <_CczBuildLayoutRoot Condition="!HasTrailingSlash('$(_CczBuildLayoutRoot)')">$(_CczBuildLayoutRoot)\</_CczBuildLayoutRoot>
      <_CczBuildRuntimeDirectory>$(_CczBuildLayoutRoot)$(CczPublishRuntimeSubdirectory)\</_CczBuildRuntimeDirectory>
    </PropertyGroup>

    <MakeDir Directories="$(_CczBuildRuntimeDirectory)" />

    <MovePortableLayoutFilesUnder Root="$(_CczBuildLayoutRoot)"
                                  RuntimeDirectory="$(_CczBuildRuntimeDirectory)"
                                  RootCompanionFiles="@(RootPackageCompanionFiles)" />

    <ItemGroup>
      <_BuildRootPackageCompanionFilesToInitialize Include="@(RootPackageCompanionFiles)"
                                                   Condition="'$(CczOverwriteRootPackageCompanionFiles)' == 'true' or !Exists('$(_CczBuildLayoutRoot)%(RootPackageCompanionFiles.TargetPath)')" />
    </ItemGroup>

    <Copy SourceFiles="@(_BuildRootPackageCompanionFilesToInitialize)"
          DestinationFiles="@(_BuildRootPackageCompanionFilesToInitialize->'$(_CczBuildLayoutRoot)%(TargetPath)')"
          SkipUnchangedFiles="true" />

    <RemoveEmptyLayoutDirectoriesUnder Root="$(_CczBuildLayoutRoot)"
                                       ExcludedRoot="$(_CczBuildRuntimeDirectory)" />

    <CreateAppHost AppHostSourcePath="$(AppHostSourcePath)"
                   AppHostDestinationPath="$(_CczBuildLayoutRoot)$(CczLauncherName)$(_NativeExecutableExtension)"
                   AppBinaryName="$(CczPublishRuntimeSubdirectory)\$(AssemblyName)$(TargetExt)"
                   IntermediateAssembly="$(_CczBuildRuntimeDirectory)$(AssemblyName)$(TargetExt)"
                   WindowsGraphicalUserInterface="true"
                   Retries="$(CopyRetryCount)"
                   RetryDelayMilliseconds="$(CopyRetryDelayMilliseconds)" />

    <VerifyPortableLayoutUnder Root="$(_CczBuildLayoutRoot)"
                               RuntimeSubdirectory="$(CczPublishRuntimeSubdirectory)"
                               LauncherName="$(CczLauncherName)"
                               AssemblyName="$(AssemblyName)"
                               NativeExecutableExtension="$(_NativeExecutableExtension)"
                               RootCompanionFiles="@(RootPackageCompanionFiles)" />
  </Target>

  <Target Name="ArrangeSelfContainedPublishLayout"
          AfterTargets="Publish"
          Condition="'$(Configuration)' == 'Release' and '$(SelfContained)' == 'true' and '$(RuntimeIdentifier)' != '' and '$(PublishSingleFile)' != 'true'">
    <PropertyGroup>
      <_CczPublishLayoutRoot>$([System.IO.Path]::GetFullPath('$(PublishDir)'))</_CczPublishLayoutRoot>
      <_CczPublishLayoutRoot Condition="!HasTrailingSlash('$(_CczPublishLayoutRoot)')">$(_CczPublishLayoutRoot)\</_CczPublishLayoutRoot>
      <_CczPublishRuntimeDirectory>$(_CczPublishLayoutRoot)$(CczPublishRuntimeSubdirectory)\</_CczPublishRuntimeDirectory>
    </PropertyGroup>

    <MakeDir Directories="$(_CczPublishRuntimeDirectory)" />

    <MovePortableLayoutFilesUnder Root="$(_CczPublishLayoutRoot)"
                                  RuntimeDirectory="$(_CczPublishRuntimeDirectory)"
                                  RootCompanionFiles="@(RootPackageCompanionFiles)" />

    <ItemGroup>
      <_PublishRootPackageCompanionFilesToInitialize Include="@(RootPackageCompanionFiles)"
                                                     Condition="'$(CczOverwriteRootPackageCompanionFiles)' == 'true' or !Exists('$(_CczPublishLayoutRoot)%(RootPackageCompanionFiles.TargetPath)')" />
    </ItemGroup>

    <Copy SourceFiles="@(_PublishRootPackageCompanionFilesToInitialize)"
          DestinationFiles="@(_PublishRootPackageCompanionFilesToInitialize->'$(_CczPublishLayoutRoot)%(TargetPath)')"
          SkipUnchangedFiles="true" />

    <RemoveEmptyLayoutDirectoriesUnder Root="$(_CczPublishLayoutRoot)"
                                       ExcludedRoot="$(_CczPublishRuntimeDirectory)" />

    <CreateAppHost AppHostSourcePath="$(AppHostSourcePath)"
                   AppHostDestinationPath="$(_CczPublishLayoutRoot)$(CczLauncherName)$(_NativeExecutableExtension)"
                   AppBinaryName="$(CczPublishRuntimeSubdirectory)\$(AssemblyName)$(TargetExt)"
                   IntermediateAssembly="$(_CczPublishRuntimeDirectory)$(AssemblyName)$(TargetExt)"
                   WindowsGraphicalUserInterface="true"
                   Retries="$(CopyRetryCount)"
                   RetryDelayMilliseconds="$(CopyRetryDelayMilliseconds)" />

    <VerifyPortableLayoutUnder Root="$(_CczPublishLayoutRoot)"
                               RuntimeSubdirectory="$(CczPublishRuntimeSubdirectory)"
                               LauncherName="$(CczLauncherName)"
                               AssemblyName="$(AssemblyName)"
                               NativeExecutableExtension="$(_NativeExecutableExtension)"
                               RootCompanionFiles="@(RootPackageCompanionFiles)" />
  </Target>

  <Target Name="ArrangeSelfContainedBuildLayoutAfterPublish"
          AfterTargets="Publish"
          Condition="'$(Configuration)' == 'Release' and '$(SelfContained)' == 'true' and '$(RuntimeIdentifier)' != '' and '$(PublishSingleFile)' != 'true'">
    <PropertyGroup>
      <_CczPostPublishBuildLayoutRoot>$([System.IO.Path]::GetFullPath('$(TargetDir)'))</_CczPostPublishBuildLayoutRoot>
      <_CczPostPublishBuildLayoutRoot Condition="!HasTrailingSlash('$(_CczPostPublishBuildLayoutRoot)')">$(_CczPostPublishBuildLayoutRoot)\</_CczPostPublishBuildLayoutRoot>
      <_CczPostPublishRuntimeDirectory>$(_CczPostPublishBuildLayoutRoot)$(CczPublishRuntimeSubdirectory)\</_CczPostPublishRuntimeDirectory>
      <_CczPostPublishDirectory>$([System.IO.Path]::GetFullPath('$(PublishDir)'))</_CczPostPublishDirectory>
      <_CczPostPublishDirectory Condition="!HasTrailingSlash('$(_CczPostPublishDirectory)')">$(_CczPostPublishDirectory)\</_CczPostPublishDirectory>
    </PropertyGroup>

    <MakeDir Directories="$(_CczPostPublishRuntimeDirectory)" />

    <MovePortableLayoutFilesUnder Root="$(_CczPostPublishBuildLayoutRoot)"
                                  RuntimeDirectory="$(_CczPostPublishRuntimeDirectory)"
                                  ExcludedRoot="$(_CczPostPublishDirectory)"
                                  RootCompanionFiles="@(RootPackageCompanionFiles)" />

    <ItemGroup>
      <_PostPublishBuildRootPackageCompanionFilesToInitialize Include="@(RootPackageCompanionFiles)"
                                                              Condition="'$(CczOverwriteRootPackageCompanionFiles)' == 'true' or !Exists('$(_CczPostPublishBuildLayoutRoot)%(RootPackageCompanionFiles.TargetPath)')" />
    </ItemGroup>

    <Copy SourceFiles="@(_PostPublishBuildRootPackageCompanionFilesToInitialize)"
          DestinationFiles="@(_PostPublishBuildRootPackageCompanionFilesToInitialize->'$(_CczPostPublishBuildLayoutRoot)%(TargetPath)')"
          SkipUnchangedFiles="true" />

    <RemoveEmptyLayoutDirectoriesUnder Root="$(_CczPostPublishBuildLayoutRoot)"
                                       ExcludedRoot="$(_CczPostPublishRuntimeDirectory)" />

    <CreateAppHost AppHostSourcePath="$(AppHostSourcePath)"
                   AppHostDestinationPath="$(_CczPostPublishBuildLayoutRoot)$(CczLauncherName)$(_NativeExecutableExtension)"
                   AppBinaryName="$(CczPublishRuntimeSubdirectory)\$(AssemblyName)$(TargetExt)"
                   IntermediateAssembly="$(_CczPostPublishRuntimeDirectory)$(AssemblyName)$(TargetExt)"
                   WindowsGraphicalUserInterface="true"
                   Retries="$(CopyRetryCount)"
                   RetryDelayMilliseconds="$(CopyRetryDelayMilliseconds)" />

    <VerifyPortableLayoutUnder Root="$(_CczPostPublishBuildLayoutRoot)"
                               RuntimeSubdirectory="$(CczPublishRuntimeSubdirectory)"
                               LauncherName="$(CczLauncherName)"
                               AssemblyName="$(AssemblyName)"
                               NativeExecutableExtension="$(_NativeExecutableExtension)"
                               RootCompanionFiles="@(RootPackageCompanionFiles)" />
  </Target>

</Project>
