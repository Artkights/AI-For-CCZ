<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Version>7.0.0</Version>
    <AssemblyVersion>7.0.0.0</AssemblyVersion>
    <FileVersion>7.0.0.0</FileVersion>
    <InformationalVersion>7.0.0+open-authoring-v7</InformationalVersion>
    <PublishSelfContained>true</PublishSelfContained>
    <ApplicationIcon>Assets\About\Doro-white.ico</ApplicationIcon>
    <DefaultItemExcludes>$(DefaultItemExcludes);bin\**;obj\**;_BuildCheck\**</DefaultItemExcludes>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <SelfContained Condition="'$(UseAppHost)' != 'false'">true</SelfContained>
    <SelfContained Condition="'$(UseAppHost)' == 'false'">false</SelfContained>
  </PropertyGroup>

  <UsingTask TaskName="RemoveEmptyLayoutDirectoriesUnder"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Root ParameterType="System.String" Required="true" />
      <ExcludedRoot ParameterType="System.String" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        var root = Path.GetFullPath(Root);
        var excludedRoot = string.IsNullOrWhiteSpace(ExcludedRoot) ? null : Path.GetFullPath(ExcludedRoot);

        if (Directory.Exists(root))
        {
            if (!root.EndsWith(Path.DirectorySeparatorChar.ToString()))
            {
                root += Path.DirectorySeparatorChar;
            }

            if (excludedRoot != null && !excludedRoot.EndsWith(Path.DirectorySeparatorChar.ToString()))
            {
                excludedRoot += Path.DirectorySeparatorChar;
            }

            foreach (var directory in Directory.EnumerateDirectories(root, "*", SearchOption.AllDirectories).OrderByDescending(path => path.Length))
            {
                var fullPath = Path.GetFullPath(directory);
                var fullPathWithSlash = fullPath.EndsWith(Path.DirectorySeparatorChar.ToString())
                    ? fullPath
                    : fullPath + Path.DirectorySeparatorChar;

                if (excludedRoot != null && fullPathWithSlash.StartsWith(excludedRoot, StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                if (!Directory.EnumerateFileSystemEntries(fullPath).Any())
                {
                    Directory.Delete(fullPath, false);
                    Log.LogMessage(MessageImportance.Low, "Removed empty output directory '{0}'.", fullPath);
                }
            }
        }
      ]]></Code>
    </Task>
  </UsingTask>

  <UsingTask TaskName="MovePortableLayoutFilesUnder"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Root ParameterType="System.String" Required="true" />
      <RuntimeDirectory ParameterType="System.String" Required="true" />
      <ExcludedRoot ParameterType="System.String" Required="false" />
      <RootCompanionFiles ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.Collections.Generic" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        static string EnsureTrailingSlash(string path)
        {
            var fullPath = Path.GetFullPath(path);
            return fullPath.EndsWith(Path.DirectorySeparatorChar.ToString(), StringComparison.Ordinal) ||
                   fullPath.EndsWith(Path.AltDirectorySeparatorChar.ToString(), StringComparison.Ordinal)
                ? fullPath
                : fullPath + Path.DirectorySeparatorChar;
        }

        static string NormalizeRelativePath(string path)
        {
            return path
                .Replace(Path.AltDirectorySeparatorChar, Path.DirectorySeparatorChar)
                .TrimStart(Path.DirectorySeparatorChar);
        }

        var root = EnsureTrailingSlash(Root);
        var runtimeDirectory = EnsureTrailingSlash(RuntimeDirectory);
        var excludedRoot = string.IsNullOrWhiteSpace(ExcludedRoot) ? null : EnsureTrailingSlash(ExcludedRoot);
        var rootCompanionRelativePaths = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var item in RootCompanionFiles ?? Array.Empty<Microsoft.Build.Framework.ITaskItem>())
        {
            var targetPath = item.GetMetadata("TargetPath");
            if (string.IsNullOrWhiteSpace(targetPath))
            {
                targetPath = Path.GetFileName(item.ItemSpec);
            }

            if (!string.IsNullOrWhiteSpace(targetPath))
            {
                rootCompanionRelativePaths.Add(NormalizeRelativePath(targetPath));
            }
        }

        if (Directory.Exists(root))
        {
            Directory.CreateDirectory(runtimeDirectory);

            foreach (var file in Directory.EnumerateFiles(root, "*", SearchOption.AllDirectories).OrderBy(path => path.Length))
            {
                var fullPath = Path.GetFullPath(file);
                if (!fullPath.StartsWith(root, StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                if (fullPath.StartsWith(runtimeDirectory, StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                if (excludedRoot != null && fullPath.StartsWith(excludedRoot, StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                if (Path.GetExtension(fullPath).Equals(".zip", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                var relativePath = fullPath.Substring(root.Length);
                if (string.IsNullOrWhiteSpace(relativePath))
                {
                    continue;
                }

                if (rootCompanionRelativePaths.Contains(NormalizeRelativePath(relativePath)))
                {
                    continue;
                }

                var destination = Path.Combine(runtimeDirectory, relativePath);
                if (fullPath.Equals(destination, StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                Directory.CreateDirectory(Path.GetDirectoryName(destination)!);
                if (File.Exists(destination))
                {
                    File.SetAttributes(destination, FileAttributes.Normal);
                    File.Delete(destination);
                }

                File.Move(fullPath, destination);
                Log.LogMessage(MessageImportance.Low, "Moved portable runtime file '{0}' to '{1}'.", fullPath, destination);
            }
        }
      ]]></Code>
    </Task>
  </UsingTask>

  <UsingTask TaskName="VerifyPortableLayoutUnder"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Root ParameterType="System.String" Required="true" />
      <RuntimeSubdirectory ParameterType="System.String" Required="true" />
      <LauncherName ParameterType="System.String" Required="true" />
      <AssemblyName ParameterType="System.String" Required="true" />
      <NativeExecutableExtension ParameterType="System.String" Required="true" />
      <RootCompanionFiles ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        var root = Path.GetFullPath(Root);
        var runtimeDirectory = Path.Combine(root, RuntimeSubdirectory);
        var requiredFiles = new[]
        {
            Path.Combine("ConfigTable", "HexTable.xml"),
            Path.Combine("LegacyResources", "a新剧本编辑器v0.23", "CczString.ini"),
            Path.Combine("LegacyResources", "a新剧本编辑器v0.23", "CczSceneEditor2.ini"),
            Path.Combine("LegacyResources", "a新剧本编辑器v0.23", "cczEditor2", "cczEditor2.rc"),
            Path.Combine("LegacyResources", "a新剧本编辑器v0.23", "cczEditor2", "cczEditor2View.cpp"),
            Path.Combine("LegacyResources", "B形象指定器", "形象指定器6.5", "System.ini"),
            Path.Combine("Assets", "About", "Doro-white.ico"),
            Path.Combine("Assets", "About", "Doro-white.png"),
            Path.Combine("Assets", "About", "doro.jpg"),
            Path.Combine("Assets", "About", "Doro.webp"),
            Path.Combine("Assets", "Palettes", "tsb"),
            Path.Combine("Assets", "PortraitFrames", "heiy01.png"),
            Path.Combine("Templates", "剧本文本导入AI说明模板.md"),
            Path.Combine("Package", "GUI-PACKAGE-MANIFEST.txt"),
            Path.Combine("Package", "self-check.json")
        };

        if (!Directory.Exists(runtimeDirectory))
        {
            Log.LogError("GUI portable package missing runtime directory: {0}", runtimeDirectory);
        }

        foreach (var relativePath in requiredFiles)
        {
            var fullPath = Path.Combine(runtimeDirectory, relativePath);
            if (!File.Exists(fullPath))
            {
                Log.LogError("GUI portable net package missing required file: {0}", fullPath);
            }
        }

        if (Directory.Exists(root))
        {
            foreach (var pattern in new[] { "*.dll", "*.json", "*.pdb" })
            {
                foreach (var file in Directory.GetFiles(root, pattern, SearchOption.TopDirectoryOnly))
                {
                    Log.LogError("GUI portable package runtime file must be under net, but root contains: {0}", file);
                }
            }

            var launcherPath = Path.Combine(root, LauncherName + NativeExecutableExtension);
            if (!File.Exists(launcherPath))
            {
                Log.LogError("GUI portable package missing root launcher: {0}", launcherPath);
            }

            if (!LauncherName.Equals(AssemblyName, StringComparison.OrdinalIgnoreCase))
            {
                var assemblyAppHostPath = Path.Combine(root, AssemblyName + NativeExecutableExtension);
                if (File.Exists(assemblyAppHostPath))
                {
                    Log.LogError("GUI portable package root must only expose the launcher; remove root apphost: {0}", assemblyAppHostPath);
                }
            }

            foreach (var item in RootCompanionFiles ?? Array.Empty<Microsoft.Build.Framework.ITaskItem>())
            {
                var targetPath = item.GetMetadata("TargetPath");
                if (string.IsNullOrWhiteSpace(targetPath))
                {
                    targetPath = Path.GetFileName(item.ItemSpec);
                }

                var fullPath = Path.Combine(root, targetPath);
                if (!File.Exists(fullPath))
                {
                    Log.LogError("GUI portable package missing root companion file: {0}", fullPath);
                }
            }
        }

      ]]></Code>
    </Task>
  </UsingTask>

  <PropertyGroup>
    <CczPublishRuntimeSubdirectory>net</CczPublishRuntimeSubdirectory>
    <CczLauncherName>普罗工具整合包</CczLauncherName>
